# PropConnect Environment Configuration Template

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=development
PORT=3000
FRONTEND_PORT=5173

# ============================================================================
# SECURITY & SECRETS
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=30d

# OAuth2 / Social Login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Two-Factor Authentication
TOTP_WINDOW=1
TOTP_BACKUP_CODES_COUNT=10

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=propconnect_user
DATABASE_PASSWORD=your-secure-database-password
DATABASE_NAME=propconnect_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=5

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=propconnect-documents-dev
AWS_S3_REGION=eu-west-1
AWS_CLOUDFRONT_DOMAIN=d123456789.cloudfront.net

# KMS for encryption
AWS_KMS_KEY_ID=arn:aws:kms:eu-west-1:123456789:key/12345678-1234-1234-1234-123456789012

# ============================================================================
# EMAIL CONFIGURATION (SendGrid)
# ============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@propconnect.it
SENDGRID_FROM_NAME=PropConnect

# Email templates
SENDGRID_VERIFICATION_EMAIL_ID=d-xxxxx
SENDGRID_PASSWORD_RESET_EMAIL_ID=d-xxxxx
SENDGRID_WELCOME_EMAIL_ID=d-xxxxx

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_URL=http://localhost:3000/v1
API_VERSION=v1
API_DOCS_ENABLED=true
API_DOCS_URL=/docs

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:5173
FRONTEND_BUILD_PATH=../frontend/dist

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=./logs

# ============================================================================
# MARKETPLACE DATA
# ============================================================================
# OMI Agenzia delle Entrate
OMI_API_KEY=your-omi-api-key
OMI_API_URL=https://api.omi.agenziaeentrate.it

# Immobiliare.it Partner API
IMMOBILIARE_API_KEY=your-immobiliare-api-key
IMMOBILIARE_API_URL=https://api.immobiliare.it

# idealista Partner API
IDEALISTA_API_KEY=your-idealista-api-key
IDEALISTA_API_URL=https://api.idealista.it

# ============================================================================
# DOCUMENT VERIFICATION
# ============================================================================
# OCR Service (Google Document AI or AWS Textract)
OCR_PROVIDER=aws_textract # or 'google_vision'
OCR_MAX_FILE_SIZE_MB=25

# Virus Scanning
VIRUS_SCAN_ENABLED=true
VIRUS_SCAN_PROVIDER=clamav # or 's3_antivirus'
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ============================================================================
# PAYMENT CONFIGURATION (Phase 2)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Sentry Error Tracking
SENTRY_DSN=https://key@sentry.io/project
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# DataDog APM
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.eu

# ============================================================================
# FEATURES FLAGS
# ============================================================================
FEATURE_EMAIL_VERIFICATION=true
FEATURE_TWO_FA=true
FEATURE_MARKET_DATA=true
FEATURE_VALUATION_ENGINE=true
FEATURE_MESSAGING=true
FEATURE_PREMIUM_SUBSCRIPTIONS=false

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
SEED_DATABASE=false
SEED_SAMPLE_DATA=true
DEBUG=propconnect:*
MOCK_EXTERNAL_SERVICES=false

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Docker
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_NAME=propconnect/backend
DOCKER_IMAGE_TAG=latest

# Kubernetes
K8S_NAMESPACE=propconnect
K8S_REPLICAS=1
K8S_RESOURCES_MEMORY_LIMIT=512Mi
K8S_RESOURCES_CPU_LIMIT=500m
