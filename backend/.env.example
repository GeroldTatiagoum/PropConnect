# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_DOCS_ENABLED=true

# ─── Skip flags (set to true to bypass a config group during local dev) ───────
SKIP_DB_CONFIG=true
SKIP_JWT_CONFIG=true
SKIP_AWS_CONFIG=true

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=propconnect

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_random_64_char_hex_string_for_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_hex_string_for_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=eu-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=propconnect-documents-dev

# ─── Email (optional) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
